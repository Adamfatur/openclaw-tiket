# Database
DATABASE_URL=postgres://claw:claw@db:5432/clawtiket?sslmode=disable
POSTGRES_DB=clawtiket
POSTGRES_USER=claw
POSTGRES_PASSWORD=claw

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h

# AWS Bedrock
AWS_REGION=ap-southeast-3
BEDROCK_MODEL=anthropic.claude-haiku-4-5-20251001-v1:0

# OpenClaw Pool
MAX_CLAW_SLOTS=3
BOOKING_TIMEOUT=600

# Server
API_PORT=8080
ENVIRONMENT=production

# Admin Seed
ADMIN_EMAIL=admin@openclaw-tiket.local
ADMIN_PASSWORD=changeme123
